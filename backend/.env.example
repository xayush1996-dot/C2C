# Server Configuration
PORT=5000
NODE_ENV=development
TRUST_PROXY=loopback
CORS_ORIGIN=http://localhost:3000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/c2c_db

# Security & Tokens
JWT_SECRET=change_me_to_a_long_cryptographically_secure_string_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_another_long_secure_string

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Calendly Configuration
CALENDLY_WEBHOOK_SECRET=your_calendly_webhook_secret

# Administrative Seeding Credentials (Not for production)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_ID=admin01
SEED_ADMIN_PASSWORD=SafeAdminPassword123
SEED_ADMIN_NAME=Initial Administrator

PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/c2c
JWT_SECRET=supersecuresecretkeyshouldbechangedinproduction123
JWT_REFRESH_SECRET=supersecuresecretkeyshouldbechangedinproduction123
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=1

# Admin Seed Credentials
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_ID=admin01
SEED_ADMIN_PASSWORD=change_this_password
SEED_ADMIN_NAME=Admin User

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Calendly Configuration
CALENDLY_WEBHOOK_SECRET=your_calendly_webhook_secret

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

{
  "info": {
    "_postman_id": "c2c-backend-api-collection",
    "name": "C2C Backend API Collection",
    "description": "Postman collection for testing the C2C backend standalone API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Customer Auth",
      "item": [
        {
          "name": "Customer Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Customer Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.environment.set(\"customerAccessToken\", jsonData.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Customer Profile (/me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Customer Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-CSRF-Token",
                "value": "csrf_mock_token_abc"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            }
          }
        },
        {
          "name": "Customer Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-CSRF-Token",
                "value": "csrf_mock_token_abc"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.accessToken) {",
                  "    pm.environment.set(\"adminAccessToken\", jsonData.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminSecurePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Admin Profile (/me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Public Enquiry",
      "item": [
        {
          "name": "Submit Enquiry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"subject\": \"General Consulting Enquiry\",\n  \"message\": \"Hello, I am interested in booking a consulting session for next week.\",\n  \"phone\": \"\" \n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/enquiries",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "enquiries"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Payments & Bookings",
      "item": [
        {
          "name": "Create Payment Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{customerAccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"consulting-1h\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/create-order",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "payments",
                "create-order"
              ]
            }
          }
        },
        {
          "name": "Verify Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{customerAccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razorpay_order_id\": \"order_mock123\",\n  \"razorpay_payment_id\": \"pay_mock456\",\n  \"razorpay_signature\": \"mock_signature_abc\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "payments",
                "verify"
              ]
            }
          }
        },
        {
          "name": "Get Customer Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/me/bookings",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "me",
                "bookings"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Dashboard & Reports",
      "item": [
        {
          "name": "Dashboard Summary Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/dashboard/summary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "dashboard",
                "summary"
              ]
            }
          }
        },
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/customers?page=1&limit=10&search=Jane",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "customers"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": "Jane"
                }
              ]
            }
          }
        },
        {
          "name": "Download Enquiries PDF Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/admin/reports/enquiries?status=PENDING",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "reports",
                "enquiries"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "customerAccessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminAccessToken",
      "value": "",
      "type": "string"
    }
  ]
}
